# Copy to .env and fill in. Do not commit .env.

PORT=3000

# Your app URL (no trailing slash). Use https in production.
BASE_URL=http://localhost:3000
# Share embed image URL (og:image). Set in Vercel to production domain so link previews show the logo.
# SITE_URL=https://your-domain.vercel.app

# Session secret (change in production)
SESSION_SECRET=your-random-secret-at-least-32-chars

# Discord Developer Portal: https://discord.com/developers/applications
# Create an application → OAuth2 → Redirects: add BASE_URL/api/discord/callback
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
# Team section: bot token to fetch Discord username/avatar by ID. Same Discord app → Bot → Reset Token → copy here.
DISCORD_BOT_TOKEN=
# Raffle announcements: Discord channel ID where the bot posts new raffles and winners. Bot must be in the server (use invite link) and have Send Messages in this channel.
# DISCORD_RAFFLE_CHANNEL_ID=

# Helius (https://dashboard.helius.dev) — for collection supply via DAS getAssetsByGroup
HELIUS_API_KEY=

# Collections: Magic Eden slug + optional on-chain collection mint (for supply + verify/holders NFT counts).
# COLLECTION_1_ME_SLUG=ugly_ape_squad
# COLLECTION_1_DISPLAY_NAME=Ugly Ape Squad
# COLLECTION_1_MINT=
# COLLECTION_2_ME_SLUG=mutant_ugly_ape_squad_collection
# COLLECTION_2_DISPLAY_NAME=Mutant Ugly Ape Squad
# COLLECTION_2_MINT=

# Project SPL token mint — used for /api/prices, /api/verify, /api/holders. Must be the token mint (Solscan / Dexscreener “base token”), NOT the Dexscreener pair address in the URL.
# TOKEN_MINT=64vQ6Km98vEZnz7a1MmgMjsaDYUL7RaLJCDmRiggBAGS
# Optional: same id as dexscreener.com/solana/<PAIR> — chart OHLC fallback if pool lookup fails
# DEXSCREENER_PAIR_ADDRESS=75uh3cMvJ51o3Jx2AmmZohjVRDe4iiiZpb9n8h7CNr3i
# Optional display ticker for raffle pricing labels (default TOKEN)
# TOKEN_SYMBOL=SERUMX
# Optional SPL decimals for TOKEN_MINT (balances / holders formatting). If omitted, the server reads decimals once from the mint account via RPC (recommended — avoids K/M/B mistakes when the mint is not 6 decimals).
# TOKEN_DECIMALS=9

# Birdeye (https://birdeye.so) — for 15m OHLC chart in token section (optional)
# BIRDEYE_API_KEY=

# Raffles: comma-separated Discord user IDs allowed to create raffles (admin panel).
# ADMIN_DISCORD_IDS=123456789,987654321
# Solana wallet address where prize NFTs are sent when a raffle starts.
# PRIZE_WALLET=
# Optional: base58 secret key for PRIZE_WALLET so the server can send the prize NFT to the winner on claim. If unset, winners see "Contact the team".
# PRIZE_WALLET_PRIVATE_KEY=
# Where ticket payments go (SOL/tokens). Defaults to PRIZE_WALLET if unset.
# RAFFLE_TREASURY_WALLET=

# Neon PostgreSQL — Discord logins, wallet linking (Verify), holders Discord names + merge by user, Pairs state. Run: npm run db:migrate
# Use sslmode=verify-full to avoid pg SSL warning (not sslmode=require)
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=verify-full
