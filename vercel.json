{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/favicon.ico", "destination": "/api/favicon" },
    { "source": "/favicon.svg", "destination": "/api/favicon.svg" },
    { "source": "/api/raffles", "destination": "/api/raffles-proxy" },
    { "source": "/api/raffles/(.*)", "destination": "/api/raffles-proxy?path=$1" },
    { "source": "/api/wait-list", "destination": "/api/wait-list-proxy" },
    { "source": "/api/wait-list/(.*)", "destination": "/api/wait-list-proxy?path=$1" },
    { "source": "/raffles", "destination": "/" },
    { "source": "/raffles/", "destination": "/" },
    { "source": "/merch-packs", "destination": "/" },
    { "source": "/merch-packs/", "destination": "/" }
  ],
  "redirects": [
    { "source": "/absurd-apes", "destination": "/", "permanent": false },
    { "source": "/absurd-apes/", "destination": "/", "permanent": false }
  ]
}
